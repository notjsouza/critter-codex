# Runtime token bundled into the app (public token, starts with pk.)
# Required permissions/scopes:
# - styles:read
# - fonts:read
# - tiles:read
# Optional depending on custom setup:
# - styles:tiles (if using custom style tiles)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_public_mapbox_token

# Build-time token for native SDK downloads (secret token, starts with sk.)
# Required permissions/scopes:
# - Downloads:Read
# Keep this token out of source control and app runtime bundles.
# Use shell env vars, local secrets, or CI/EAS secret storage.
MAPBOX_DOWNLOADS_TOKEN=sk.your_mapbox_download_token

# Base URL for your Lambda/API Gateway backend.
# Example: https://abc123.execute-api.us-east-1.amazonaws.com
# When omitted, the app falls back to local in-memory mock entries.
EXPO_PUBLIC_API_BASE_URL=
